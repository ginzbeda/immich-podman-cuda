# --- DATABASE & AUTH ---
DB_PASSWORD=your_secure_password
DB_HOSTNAME=immich_postgres
DB_USERNAME=postgres
DB_DATABASE_NAME=immich

# --- TIERED STORAGE ARCHITECTURE ---

# 1. SSD / HOT DATA (High IOPS)
# Store PostgreSQL, Redis, and system config here for snappy UI and metadata searches.
# Recommended: /mnt/e/Nexus/Config/Immich
IMMICH_CONFIG_LOCATION=/path/to/ssd/storage

# 2. HDD / COLD DATA (Bulk Storage)
# Store the main upload library, thumbnails, and encoded videos here.
# Recommended: /mnt/d/Media/Library
IMMICH_STORAGE_LOCATION=/path/to/hdd/storage

# --- VERSIONING ---
IMMICH_VERSION=release

# --- HARDWARE ACCELERATION (NVIDIA) ---
NVIDIA_VISIBLE_DEVICES=all
NVIDIA_DRIVER_CAPABILITIES=all,compute,utility,video

# Force Machine Learning to use CUDA (e.g., GTX 1080)
IMMICH_MACHINE_LEARNING_DEVICE=cuda
IMMICH_MACHINE_LEARNING_MODEL_TTL=300

# --- NETWORK ---
# Ensures Immich binds to all interfaces for container networking
IMMICH_HOST=0.0.0.0